{
  "name": "@jscadui/jscad-web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node build.js --dev --skipDocs",
    "sync-examples": "cp -r examples/. build_dev/examples/",
    "dev:full": "node build.js --dev",
    "build": "node build.js",
    "serve": "node build.js --serve",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "eslint src src_bundle src_build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.1.9",
    "@jscad/csg": "0.7.0",
    "@jscad/io": "2.4.7",
    "@jscad/modeling": "npm:@jbroll/jscad-modeling@^2.13.3",
    "@jscadui/format-common": "*",
    "@jscadui/format-jscad": "*",
    "@jscadui/format-threejs": "*",
    "@jscadui/fs-provider": "*",
    "@jscadui/fs-serviceworker": "*",
    "@jscadui/html-gizmo": "*",
    "@jscadui/openscad": "*",
    "@jscadui/orbit": "^0.1.0",
    "@jscadui/params": "*",
    "@jscadui/params-controller": "*",
    "@jscadui/params-core": "*",
    "@jscadui/params-ui": "*",
    "@jscadui/postmessage": "*",
    "@jscadui/render-regl": "*",
    "@jscadui/render-threejs": "*",
    "@jscadui/scene": "*",
    "@jscadui/transform-babel": "*",
    "@jscadui/worker": "*",
    "codemirror": "^6.0.1",
    "fflate": "0.8.1",
    "gl-matrix": "^3.4.0",
    "regl": "^2.1.0",
    "three": "^0.147.0"
  },
  "devDependencies": {
    "@jbroll/jsx6-build": "^0.3.0",
    "@playwright/test": "^1.58.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/browser": "^4.0.18",
    "esbuild": "^0.27.2",
    "live-server": "^1.2.0",
    "npm-run-all": "^4.1.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}

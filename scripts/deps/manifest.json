{
  "version": "1",
  "cacheDir": ".deps-cache",
  "deps": [
    {
      "name": "bosl-lib",
      "description": "BOSL v1 library source files",
      "url": "https://github.com/revarbat/BOSL.git",
      "ref": "master",
      "commit": null,
      "license": "LGPL-2.1",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "packages/openscad/test/corpus/bosl/lib",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        },
        {
          "srcDir": "examples",
          "destDir": "packages/openscad/test/corpus/bosl",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        }
      ],
      "patches": [
        {
          "file": "packages/openscad/test/corpus/bosl/bezier_patches.scad",
          "description": "Rewrite BOSL/ include paths to local lib/",
          "replace": "BOSL/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl/orientations.scad",
          "description": "Rewrite BOSL/ include paths to local lib/",
          "replace": "BOSL/",
          "with": "lib/"
        }
      ]
    },
    {
      "name": "bosl2-lib",
      "description": "BOSL2 library source files",
      "url": "https://github.com/BelfrySCAD/BOSL2.git",
      "ref": "master",
      "commit": null,
      "license": "BSD-2-Clause",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "packages/openscad/test/corpus/bosl2/lib",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        },
        {
          "srcDir": "examples",
          "destDir": "packages/openscad/test/corpus/bosl2",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        }
      ],
      "patches": [
        {
          "file": "packages/openscad/test/corpus/bosl2/BOSL2logo.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/attachments.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/boolean_geometry.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/fractal_tree.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/lsystems.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/orientations.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/spherical_patch.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        },
        {
          "file": "packages/openscad/test/corpus/bosl2/spring_handle.scad",
          "description": "Rewrite BOSL2/ include paths to local lib/",
          "replace": "BOSL2/",
          "with": "lib/"
        }
      ]
    },
    {
      "name": "bosl-corpus",
      "description": "BOSL v1 example .scad files extracted from library inline examples",
      "generated": true,
      "script": "packages/openscad/bin/extract-bosl1-examples.js",
      "cwd": "packages/openscad",
      "requires": ["bosl-lib"],
      "patches": []
    },
    {
      "name": "bosl2-corpus",
      "description": "BOSL2 example .scad files extracted from library inline examples",
      "generated": true,
      "script": "packages/openscad/bin/extract-bosl2-examples.js",
      "cwd": "packages/openscad",
      "requires": ["bosl2-lib"],
      "patches": []
    },
    {
      "name": "nopscadlib",
      "description": "NopSCADlib library source files and component test files",
      "url": "https://github.com/nophead/NopSCADlib.git",
      "ref": "master",
      "commit": null,
      "license": "GPL-3.0",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "apps/jscad-web/examples/openscad/nopscadlib/NopSCADlib",
          "include": ["*.scad", "**/*.scad"],
          "exclude": ["examples/**"],
          "skipFiles": []
        }
      ],
      "patches": []
    },
    {
      "name": "snippet",
      "description": "OpenSCAD community code snippets (AngeloNicoli/OpenSCAD-Snippet)",
      "url": "https://github.com/AngeloNicoli/OpenSCAD-Snippet.git",
      "ref": "main",
      "commit": null,
      "license": "mixed",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "packages/openscad/test/corpus/snippet",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md", "LICENSE"],
          "skipFiles": []
        },
        {
          "srcDir": "Animation_SCAD",
          "destDir": "packages/openscad/test/corpus/snippet/Animation_SCAD",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md"],
          "skipFiles": []
        },
        {
          "srcDir": "Asset_SCAD",
          "destDir": "packages/openscad/test/corpus/snippet/Asset_SCAD",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md"],
          "skipFiles": []
        },
        {
          "srcDir": "Image",
          "destDir": "packages/openscad/test/corpus/snippet/Image",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md"],
          "skipFiles": []
        }
      ],
      "patches": []
    }
  ],
  "organize": {
    "description": "Organize corpus into numbered example batches for the web app",
    "script": "packages/openscad/bin/organize-corpus.js",
    "args": ["--force"]
  }
}

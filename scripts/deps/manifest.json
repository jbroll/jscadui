{
  "version": "1",
  "cacheDir": ".deps-cache",
  "deps": [
    {
      "name": "bosl-lib",
      "description": "BOSL v1 library source files",
      "url": "https://github.com/revarbat/BOSL.git",
      "ref": "master",
      "commit": "4ce427a8a38786e5f74b728c1e33d9fe7d4904d2",
      "license": "LGPL-2.1",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "packages/openscad/test/corpus/bosl/lib",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        },
        {
          "srcDir": "examples",
          "destDir": "packages/openscad/test/corpus/bosl",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        }
      ],
      "patches": [
        {
          "patchFile": "scripts/deps/patches/bosl-lib-fix-includes.patch",
          "description": "Rewrite BOSL/ include paths to local lib/"
        }
      ]
    },
    {
      "name": "bosl2-lib",
      "description": "BOSL2 library source files",
      "url": "https://github.com/BelfrySCAD/BOSL2.git",
      "ref": "master",
      "commit": "68bae2d7e0675c2923af7e012bd39f1931fea09d",
      "license": "BSD-2-Clause",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "packages/openscad/test/corpus/bosl2/lib",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        },
        {
          "srcDir": "examples",
          "destDir": "packages/openscad/test/corpus/bosl2",
          "include": ["*.scad"],
          "exclude": [],
          "skipFiles": []
        }
      ],
      "patches": [
        {
          "patchFile": "scripts/deps/patches/bosl2-lib-fix-includes.patch",
          "description": "Rewrite BOSL2/ include paths to local lib/"
        }
      ]
    },
    {
      "name": "bosl-corpus",
      "description": "BOSL v1 example .scad files extracted from library inline examples",
      "generated": true,
      "script": "packages/openscad/bin/extract-bosl1-examples.js",
      "cwd": "packages/openscad",
      "requires": ["bosl-lib"],
      "patches": [
        {
          "patchFile": "scripts/deps/patches/bosl-corpus-joiners-shapes-dep.patch",
          "description": "Add explicit shapes.scad dep — example uses cuboid() which joiners.scad imports transitively"
        }
      ]
    },
    {
      "name": "bosl2-corpus",
      "description": "BOSL2 example .scad files extracted from library inline examples",
      "generated": true,
      "script": "packages/openscad/bin/extract-bosl2-examples.js",
      "cwd": "packages/openscad",
      "requires": ["bosl2-lib"],
      "patches": []
    },
    {
      "name": "nopscadlib",
      "description": "NopSCADlib library source files and component test files",
      "url": "https://github.com/nophead/NopSCADlib.git",
      "ref": "master",
      "commit": "c9baa0ed0faa23e849141c3d8c6728545d6af910",
      "license": "GPL-3.0",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "apps/jscad-web/examples/openscad/nopscadlib/NopSCADlib",
          "include": ["*.scad", "**/*.scad"],
          "exclude": ["examples/**"],
          "skipFiles": []
        }
      ],
      "patches": []
    },
    {
      "name": "dotscad",
      "description": "dotSCAD OpenSCAD utility library (JustinSDK/dotSCAD)",
      "url": "https://github.com/JustinSDK/dotSCAD.git",
      "ref": "master",
      "commit": "bb33edfd75cba0edbb7971606a077b9c69d0b7d2",
      "license": "LGPL-3.0",
      "mappings": [
        {
          "srcDir": "src",
          "destDir": "apps/jscad-web/examples/openscad/dotscad",
          "include": ["*.scad", "**/*.scad"],
          "exclude": [],
          "skipFiles": []
        },
        {
          "srcDir": "examples",
          "destDir": "apps/jscad-web/examples/openscad/dotscad/examples",
          "include": ["*.scad", "**/*.scad"],
          "exclude": [],
          "skipFiles": []
        }
      ],
      "patches": [
        {
          "patchFile": "scripts/deps/patches/dotscad-maze-rand-dirs-seed.patch",
          "description": "Use position-based seed in rand_dirs — makes all maze models deterministic"
        },
        {
          "patchFile": "scripts/deps/patches/dotscad-tile-truchet-seed.patch",
          "description": "Use position-based seed in tile_truchet — makes all truchet tile models deterministic"
        },
        {
          "patchFile": "scripts/deps/patches/dotscad-examples-seed-rands.patch",
          "description": "Seed rands() in 6 example files for deterministic output"
        }
      ]
    },
    {
      "name": "snippet",
      "description": "OpenSCAD community code snippets (AngeloNicoli/OpenSCAD-Snippet)",
      "url": "https://github.com/AngeloNicoli/OpenSCAD-Snippet.git",
      "ref": "main",
      "commit": "a718aaf84821dc229353257359cf940f7dbd90da",
      "license": "mixed",
      "mappings": [
        {
          "srcDir": ".",
          "destDir": "packages/openscad/test/corpus/snippet",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md", "LICENSE"],
          "skipFiles": []
        },
        {
          "srcDir": "Animation_SCAD",
          "destDir": "packages/openscad/test/corpus/snippet/Animation_SCAD",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md"],
          "skipFiles": []
        },
        {
          "srcDir": "Asset_SCAD",
          "destDir": "packages/openscad/test/corpus/snippet/Asset_SCAD",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md"],
          "skipFiles": []
        },
        {
          "srcDir": "Image",
          "destDir": "packages/openscad/test/corpus/snippet/Image",
          "include": ["*.scad", "*.txt", "*.png"],
          "exclude": ["*.md"],
          "skipFiles": []
        }
      ],
      "patches": [
        {
          "patchFile": "scripts/deps/patches/snippet-bricks-seed-rands.patch",
          "description": "Seed rands() calls in Bricks.scad for deterministic output across test runs"
        }
      ]
    }
  ],
  "organize": {
    "description": "Organize corpus into numbered example batches for the web app",
    "script": "packages/openscad/bin/organize-corpus.js",
    "args": ["--force"]
  }
}

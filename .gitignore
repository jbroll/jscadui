# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1 declaration files
typings/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and *not* Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# External OpenSCAD dependencies — populated by `npm run fetch-deps`
# Managed via scripts/deps/manifest.json — never commit these
.deps-cache/
packages/openscad/test/corpus/bosl/lib/
packages/openscad/test/corpus/bosl2/lib/
packages/openscad/test/corpus/snippet/

# BOSL corpus examples are generated from lib/ by extract-bosl{1,2}-examples.js
# Keep: skip.txt, manifest.json
packages/openscad/test/corpus/bosl/*.scad
packages/openscad/test/corpus/bosl2/*.scad

# Organized examples — generated by organize-corpus.js from corpus
# skip.txt and exclude.txt are hand-maintained and must be tracked
apps/jscad-web/examples/openscad/bosl/**
apps/jscad-web/examples/openscad/bosl2/**
apps/jscad-web/examples/openscad/snippet/**
!apps/jscad-web/examples/openscad/bosl/skip.txt
!apps/jscad-web/examples/openscad/bosl/exclude.txt
!apps/jscad-web/examples/openscad/bosl2/skip.txt
!apps/jscad-web/examples/openscad/bosl2/exclude.txt
!apps/jscad-web/examples/openscad/snippet/skip.txt

# Turbo
.turbo
**/build/**
build_dev/**
dist/**
**/esm/
**/.history
**/.idea
apps/myapp

# Test snapshots
__snapshots__

# Local deployment config (use deploy.conf.example as template)
deploy.conf
.playwright-mcp/

# Root-level debug screenshots and temporary files
/*.png
/*.md.tmp
/all-js-*.md

{
  "type": "module",
  "sideEffects": false,
  "name": "@jscadui/openscad",
  "version": "0.1.0",
  "description": "OpenSCAD to JSCAD translator",
  "main": "./esm/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "bin": {
    "scad2jscad": "./bin/scad2jscad.js",
    "run-jscad": "./bin/run-jscad.js",
    "compare-stl": "./bin/compare-stl.js",
    "test-harness": "./bin/test-harness.js"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    }
  },
  "files": [
    "esm",
    "bin"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test:corpus": "node bin/test-harness.js --corpus",
    "test:bosl": "node bin/test-harness.js --dir test/corpus/bosl",
    "test:snippet": "node bin/test-harness.js --dir test/corpus/snippet/Asset_SCAD --skip-file test/corpus/snippet-skip.txt",
    "test:all": "npm run build && npm run test && npm run test:corpus && npm run test:bosl && npm run test:snippet"
  },
  "dependencies": {
    "openscad-parser": "file:/home/john/src/openscad-parser",
    "@jscadui/manifold": "file:../manifold",
    "@jscad/modeling-for-manifold": "file:/home/john/pkg/OpenJSCAD.org/packages/modeling"
  },
  "devDependencies": {
    "@jscad/modeling": "^2.12.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}

{
  "type": "module",
  "sideEffects": false,
  "name": "@jscadui/openscad",
  "version": "0.1.0",
  "description": "OpenSCAD to JSCAD translator",
  "main": "./esm/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "bin": {
    "scad2jscad": "./bin/scad2jscad.js"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    }
  },
  "files": [
    "esm",
    "bin"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "openscad-parser": "^0.6.3"
  },
  "devDependencies": {
    "@jscad/modeling": "^2.12.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}

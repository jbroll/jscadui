{
  "type": "module",
  "sideEffects": false,
  "name": "@jscadui/openscad",
  "version": "0.1.0",
  "description": "OpenSCAD to JSCAD translator",
  "main": "./esm/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "bin": {
    "scad2jscad": "./bin/scad2jscad.js",
    "run-jscad": "./bin/run-jscad.js",
    "compare-stl": "./bin/compare-stl.js",
    "test-harness": "./bin/test-harness.js",
    "test-parallel": "./bin/test-parallel.js"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    }
  },
  "files": [
    "esm",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run test:ci",
    "test:local": "npm run build && npm run test:unit && npm run test:comparison",
    "test:ci": "cd ../.. && JOB=$(../simple-ci/ci-push.sh jscadui/packages/openscad/test:local) && ../simple-ci/ci-wait.sh \"$JOB\"",
    "test:unit": "vitest run",
    "test:comparison": "node bin/test-parallel.js ../../apps/jscad-web/examples/openscad",
    "test:bosl": "node bin/test-harness.js ../../apps/jscad-web/examples/openscad/bosl",
    "test:bosl2": "node bin/test-harness.js ../../apps/jscad-web/examples/openscad/bosl2",
    "test:snippet": "node bin/test-harness.js ../../apps/jscad-web/examples/openscad/snippet",
    "test:basics": "node bin/test-harness.js ../../apps/jscad-web/examples/openscad/01-basics",
    "test:nopscadlib": "node bin/test-harness.js ../../apps/jscad-web/examples/openscad/nopscadlib/NopSCADlib/tests --preview",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openscad-parser": "file:/home/john/src/openscad-parser",
    "@jscadui/manifold": "file:../manifold",
    "@jscadui/openscad-runtime": "file:../openscad-runtime",
    "@jscad/modeling-for-manifold": "file:/home/john/pkg/OpenJSCAD.org/packages/modeling"
  },
  "devDependencies": {
    "@jscad/modeling": "^2.12.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}

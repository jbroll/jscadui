{
  "type": "module",
  "sideEffects": false,
  "name": "@jscadui/modeling-preview",
  "version": "0.1.0",
  "description": "@jscad/modeling wrapper to allow faster development by turning on/off boleans and previewing them instead",
  "main": "index.js",
  "unpkg": "cjs/index.js",
  "module": "./index.js",
  "files": [
    "index.js",
    "src",
    "esm",

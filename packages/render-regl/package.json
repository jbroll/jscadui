{
  "type": "module",
  "sideEffects": false,
  "name": "@jscadui/render-regl",
  "version": "0.1.0",
  "description": "Self-contained JSCAD regl renderer with built-in shaders",
  "main": "index.js",
  "unpkg": "cjs/index.js",
  "module": "./index.js",
  "files": [
    "index.js",
    "src",
    "bundle.example.js",
    "esm",
    "cjs"
  ],
  "scripts": {
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "esbuild index.js --outdir=esm --bundle --sourcemap --minify --loader:.js=jsx --format=esm --external:regl --external:gl-mat4 --external:gl-vec3 --external:@jscadui/format-regl --external:@jscadui/scene",
    "build-cjs": "esbuild index.js --outdir=cjs --bundle --sourcemap --minify --loader:.js=jsx --format=cjs --external:regl --external:gl-mat4 --external:gl-vec3 --external:@jscadui/format-regl --external:@jscadui/scene",
    "prepublishOnly": "npm run build && npm run build-cjs"
  },
  "dependencies": {
    "@jscadui/format-regl": "*",
    "@jscadui/scene": "*",
    "gl-mat4": "^1.2.0",
    "gl-vec3": "^1.1.3"
  },
  "peerDependencies": {
    "regl": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "regl": {
      "optional": false
    }
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "18.11.9",
    "esbuild": "^0.27.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}

{
  "type": "module",
  "sideEffects": false,
  "name": "@jscadui/worker",
  "version": "0.1.0",
  "description": "worker for executing jscad scripts",
  "main": "worker.js",
  "unpkg": "cjs/worker.js",
  "module": "./worker.js",
  "files": [
    "worker.js",
    "src",
    "esm",
    "cjs"
  ],
  "scripts": {
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "esbuild worker.js --outdir=esm --bundle --sourcemap --minify --loader:.js=jsx --format=esm",
    "build-cjs": "esbuild worker.js --outdir=cjs --bundle --sourcemap --minify --loader:.js=jsx --format=cjs",
    "prepublishOnly": "npm run build && npm run build-cjs"
  },
  "dependencies": {
    "@jscadui/format-common": "*",
    "@jscadui/params-core": "*",
    "@jscadui/postmessage": "*",
    "@jscadui/require": "*"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "18.11.9",
    "esbuild": "^0.27.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}

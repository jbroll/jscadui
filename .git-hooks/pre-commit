#!/bin/sh
set -e

echo "Running pre-commit checks..."

# Build the openscad package (ensures transpiler JS is up to date)
echo "Building..."
npm run build --workspace=@jscadui/openscad

# Lint only staged JS/TS files
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$' || true)

if [ -n "$STAGED_JS" ]; then
  echo "Linting staged files..."
  echo "$STAGED_JS" | xargs npx eslint --max-warnings=0
fi

# Type check
echo "Type checking..."
npm run typecheck

# Run unit tests only (fast, local)
# Full comparison suite runs via CI (npm test) — too slow for pre-commit.
echo "Running unit tests..."
npm run test:unit --workspace=@jscadui/openscad

echo "All pre-commit checks passed!"

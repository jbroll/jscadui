{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./packages/tsconfig/base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node"
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.js",
    "packages/*/*.ts",
    "packages/*/*.js",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.js",
    "apps/*/*.ts",
    "apps/*/*.js",
    "file-format/*/*.ts",
    "file-format/*/*.js"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/build/**",
    "**/build_dev/**",
    "**/esm/**",
    "**/cjs/**",
    "**/jscad/**",
    "**/*.test.js",
    "**/*.test.ts"
  ]
}

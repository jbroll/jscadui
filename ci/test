#!/usr/bin/env bash
set -euo pipefail

WORKTREE="$(cd "$(dirname "$0")/.." && pwd)"

cd "$WORKTREE"
npm install

cd "$WORKTREE/packages/openscad"
npm install
# Pre-download Liberation fonts so text() works in Node.js (CDN fonts can't load synchronously)
node bin/download-fonts.js
export JSCADUI_CI=1
npm run test:local
